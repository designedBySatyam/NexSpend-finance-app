PORT=4000

# Optional MongoDB
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexspend
# MONGODB_DB_NAME=nexspend

# Password reset email (SMTP)
APP_DISPLAY_NAME=NexSpend
RESET_CODE_TTL_MINUTES=15
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=NexSpend <your-email@gmail.com>

# Optional SMTP timeout tuning (milliseconds)
# SMTP_CONNECTION_TIMEOUT_MS=10000
# SMTP_GREETING_TIMEOUT_MS=10000
# SMTP_SOCKET_TIMEOUT_MS=15000
# SMTP_SEND_TIMEOUT_MS=15000
